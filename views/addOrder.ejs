<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SweetBake - Add Order</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <% if (user.role === 'admin') { %>
    <div class="sidebar sidebar-admin">
      <div class="sidebar-brand">
        🎂 SweetBake Admin
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/admin/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/products" class="sidebar-link">Products</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/orders" class="sidebar-link active">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/inventory" class="sidebar-link">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/reports" class="sidebar-link">Reports</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } else if (user.role === 'staff') { %>
    <div class="sidebar sidebar-staff">
      <div class="sidebar-brand">
        🍰 SweetBake Staff
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/staff/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/orders" class="sidebar-link active">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/inventory" class="sidebar-link">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } %>

  <div class="main-content">
    <div class="card p-5">
      <h1 class="cake-emoji text-center">Add Order</h1>
      <form method="POST" action="/<%= user.role %>/orders/add">
        <div class="mb-4">
          <label class="form-label">Customer</label>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="customerOption" id="existingCustomer" value="existing" checked>
            <label class="form-check-label" for="existingCustomer">
              Select existing customer
            </label>
          </div>
          <div class="mb-2" id="existingCustomerDiv">
            <select class="form-control" id="customer_id" name="customer_id">
              <option value="">Select a customer</option>
              <% customers.forEach(customer => { %>
                <option value="<%= customer.id %>"><%= customer.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="customerOption" id="newCustomer" value="new">
            <label class="form-check-label" for="newCustomer">
              Add new customer
            </label>
          </div>
          <div class="mb-2" id="newCustomerDiv" style="display: none;">
            <input type="text" class="form-control" id="newCustomerName" name="newCustomerName" placeholder="Enter customer name">
          </div>
        </div>
        <div class="mb-4">
          <label for="total_amount" class="form-label">Total Amount</label>
          <input type="number" step="0.01" class="form-control" id="total_amount" name="total_amount" required>
        </div>
        <div class="mb-4">
          <label for="payment_method" class="form-label">Payment Method</label>
          <select class="form-control" id="payment_method" name="payment_method" required>
            <option value="GCash">GCash</option>
            <option value="Cash on Delivery">Cash on Delivery</option>
          </select>
        </div>
        <div class="text-center">
          <button type="submit" class="btn btn-primary btn-lg">Add Order</button>
          <a href="/<%= user.role %>/orders" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
      </form>
      
      <script>
        document.getElementById('existingCustomer').addEventListener('change', function() {
          document.getElementById('existingCustomerDiv').style.display = 'block';
          document.getElementById('newCustomerDiv').style.display = 'none';
        });
        document.getElementById('newCustomer').addEventListener('change', function() {
          document.getElementById('existingCustomerDiv').style.display = 'none';
          document.getElementById('newCustomerDiv').style.display = 'block';
        });
      </script>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>