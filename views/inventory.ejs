<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SweetBake - Inventory</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <% if (user.role === 'admin') { %>
    <div class="sidebar sidebar-admin">
      <div class="sidebar-brand">
        🎂 SweetBake Admin
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/admin/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/products" class="sidebar-link">Products</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/orders" class="sidebar-link">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/inventory" class="sidebar-link active">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/reports" class="sidebar-link">Reports</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } else if (user.role === 'staff') { %>
    <div class="sidebar sidebar-staff">
      <div class="sidebar-brand">
        🍰 SweetBake Staff
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/staff/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/orders" class="sidebar-link">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/inventory" class="sidebar-link active">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } %>

  <div class="main-content">
    <h1 class="cake-emoji">Inventory</h1>
    <% if (user.role === 'admin') { %>
      <a href="/admin/inventory/add" class="btn btn-primary mb-3">Add Ingredient</a>
    <% } %>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>ID</th>
          <th>Ingredient Name</th>
          <th>Quantity</th>
          <% if (user.role === 'admin') { %>
            <th>Actions</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% inventory.forEach(item => { %>
          <tr class="<%= item.quantity < 10 ? 'table-danger' : '' %>">
            <td><%= item.id %></td>
            <td><%= item.ingredient_name %></td>
            <td><%= item.quantity %></td>
            <% if (user.role === 'admin') { %>
              <td>
                <a href="/admin/inventory/edit/<%= item.id %>" class="btn btn-sm btn-warning">Edit</a>
                <a href="/admin/inventory/delete/<%= item.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</a>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
