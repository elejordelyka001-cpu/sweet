<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SweetBake - Orders</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <% if (user.role === 'admin') { %>
    <div class="sidebar sidebar-admin">
      <div class="sidebar-brand">
        🎂 SweetBake Admin
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/admin/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/products" class="sidebar-link">Products</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/orders" class="sidebar-link active">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/inventory" class="sidebar-link">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/reports" class="sidebar-link">Reports</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } else if (user.role === 'staff') { %>
    <div class="sidebar sidebar-staff">
      <div class="sidebar-brand">
        🍰 SweetBake Staff
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/staff/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/orders" class="sidebar-link active">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/inventory" class="sidebar-link">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } %>

  <div class="main-content">
    <h1 class="cake-emoji">Orders</h1>
    <% if (user.role === 'admin') { %>
      <a href="/admin/orders/add" class="btn btn-primary mb-3">Add Order</a>
    <% } else if (user.role === 'staff') { %>
      <a href="/staff/orders/add" class="btn btn-primary mb-3">Add Order</a>
    <% } %>
    <div class="card">
      <div class="card-body">
        <table class="table">
          <thead class="table-primary">
            <tr>
              <th>Order ID</th>
              <th>Customer</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
              <tr>
                <td><%= order.id %></td>
                <td><%= order.customer_name %></td>
                <td><%= order.status %></td>
                <td>
                  <a href="/orders/<%= order.id %>" class="btn btn-sm btn-info">View</a>
                  <% if (user.role === 'staff' || user.role === 'admin') { %>
                    <form method="POST" action="/staff/orders/<%= order.id %>/status" style="display:inline;">
                      <select name="status" class="form-select form-select-sm" style="width:auto;display:inline;">
                        <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Confirmed" <%= order.status === 'Confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="Baking" <%= order.status === 'Baking' ? 'selected' : '' %>>Baking</option>
                        <option value="Ready for Delivery" <%= order.status === 'Ready for Delivery' ? 'selected' : '' %>>Ready for Delivery</option>
                        <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                        <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                      </select>
                      <button type="submit" class="btn btn-sm btn-success">Update</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
