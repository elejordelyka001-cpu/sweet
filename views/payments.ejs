<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SweetBake - Payments</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <% if (user.role === 'admin') { %>
    <div class="sidebar sidebar-admin">
      <div class="sidebar-brand">
        🎂 SweetBake Admin
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/admin/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/products" class="sidebar-link">Products</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/orders" class="sidebar-link">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/inventory" class="sidebar-link">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/payments" class="sidebar-link active">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/admin/reports" class="sidebar-link">Reports</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } else if (user.role === 'staff') { %>
    <div class="sidebar sidebar-staff">
      <div class="sidebar-brand">
        🍰 SweetBake Staff
      </div>
      <ul class="sidebar-menu">
        <li class="sidebar-item">
          <a href="/staff/dashboard" class="sidebar-link">Dashboard</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/orders" class="sidebar-link">Orders</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/inventory" class="sidebar-link">Inventory</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/payments" class="sidebar-link active">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
      </ul>
    </div>
  <% } %>

  <div class="main-content">
    <h1 class="cake-emoji">Payments</h1>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Payment ID</th>
          <th>Order ID</th>
          <th>Payment Method</th>
          <th>Payment Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% payments.forEach(payment => { %>
          <tr>
            <td><%= payment.id %></td>
            <td><%= payment.order_id %></td>
            <td><%= payment.payment_method %></td>
            <td><%= payment.payment_status %></td>
            <td><%= payment.created_at %></td>
            <td>
              <% if (payment.payment_status === 'Pending') { %>
                <form method="POST" action="/staff/payments/<%= payment.id %>/confirm" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-success">Confirm Payment</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
