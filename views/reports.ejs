<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SweetBake - Reports</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <% if (user.role === 'admin') { %>
    <div class="sidebar sidebar-admin">
    <div class="sidebar-brand">
      🎂 SweetBake Admin
    </div>
    <ul class="sidebar-menu">
      <li class="sidebar-item">
        <a href="/admin/dashboard" class="sidebar-link">Dashboard</a>
      </li>
      <li class="sidebar-item">
        <a href="/admin/products" class="sidebar-link">Products</a>
      </li>
      <li class="sidebar-item">
        <a href="/admin/orders" class="sidebar-link">Orders</a>
      </li>
      <li class="sidebar-item">
        <a href="/admin/inventory" class="sidebar-link">Inventory</a>
      </li>
      <li class="sidebar-item">
        <a href="/admin/payments" class="sidebar-link">Payments</a>
      </li>
      <li class="sidebar-item">
          <a href="/admin/reports" class="sidebar-link active">Reports</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
    </ul>
  </div>
  <% } else if (user.role === 'staff') { %>
  <div class="sidebar sidebar-staff">
    <div class="sidebar-brand">
      🍰 SweetBake Staff
    </div>
    <ul class="sidebar-menu">
      <li class="sidebar-item">
        <a href="/staff/dashboard" class="sidebar-link">Dashboard</a>
      </li>
      <li class="sidebar-item">
        <a href="/staff/orders" class="sidebar-link">Orders</a>
      </li>
      <li class="sidebar-item">
        <a href="/staff/inventory" class="sidebar-link">Inventory</a>
      </li>
      <li class="sidebar-item">
          <a href="/staff/payments" class="sidebar-link">Payments</a>
        </li>
        <li class="sidebar-item">
          <a href="/staff/reports" class="sidebar-link active">Reports</a>
        </li>
        <li class="sidebar-item">
          <a href="/logout" class="sidebar-link">Logout</a>
        </li>
    </ul>
  </div>
  <% } %>

  <div class="main-content">
  
    <h1 class="cake-emoji text-center">Reports</h1>
    
    <div class="row mt-5">
      <div class="col-lg-6 mb-4">
        <div class="card p-4">
          <h3 class="text-center mb-3">📊 Daily Sales (Last 30 Days)</h3>
          <div class="table-responsive">
            <table class="table">
              <thead class="table-primary">
                <tr><th>Date</th><th>Total Sales</th></tr>
              </thead>
              <tbody>
                <% dailySales.forEach(sale => { %>
                  <tr><td><%= sale.date %></td><td>₱<%= sale.total %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="col-lg-6 mb-4">
        <div class="card p-4">
          <h3 class="text-center mb-3">📈 Monthly Sales</h3>
          <div class="table-responsive">
            <table class="table">
              <thead class="table-success">
                <tr><th>Month</th><th>Total Sales</th></tr>
              </thead>
              <tbody>
                <% monthlySales.forEach(sale => { %>
                  <tr><td><%= sale.month %></td><td>₱<%= sale.total %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    
    <div class="row mt-4">
      <div class="col-lg-6 mb-4">
        <div class="card p-4">
          <h3 class="text-center mb-3">🏆 Best Selling Cakes</h3>
          <div class="table-responsive">
            <table class="table">
              <thead class="table-warning">
                <tr><th>Cake Name</th><th>Total Quantity Sold</th></tr>
              </thead>
              <tbody>
                <% bestSelling.forEach(cake => { %>
                  <tr><td><%= cake.cake_name %></td><td><%= cake.total_quantity %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      
      <div class="col-lg-6 mb-4">
        <div class="card p-4">
          <h3 class="text-center mb-3">📦 Inventory Report</h3>
          <div class="table-responsive">
            <table class="table">
              <thead class="table-info">
                <tr><th>Ingredient</th><th>Quantity</th></tr>
              </thead>
              <tbody>
                <% inventory.forEach(item => { %>
                  <tr class="<%= item.quantity < 10 ? 'table-danger' : '' %>"><td><%= item.ingredient_name %></td><td><%= item.quantity %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
